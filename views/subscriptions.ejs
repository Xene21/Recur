<%
    body = `
        <div class="flex flex-col lg:flex-row lg:items-center justify-between gap-6 mb-12">
            <div>
                <h1 class="text-4xl font-extrabold tracking-tighter text-slate-900">Your Subscriptions</h1>
                <p class="text-slate-500">Manage your active subscriptions and keep track of your spending.</p>
            </div>
            <div class="flex flex-col sm:flex-row items-center gap-4">
                <div class="relative w-full sm:w-64">
                    <input 
                        type="text" 
                        id="subscriptionSearch" 
                        placeholder="Search subscriptions..." 
                        class="w-full pl-10 pr-4 py-3 bg-white border border-slate-200 rounded-xl focus:ring-2 focus:ring-slate-900 outline-none transition-all shadow-sm"
                    >
                    <i class="ph-bold ph-magnifying-glass absolute left-3 top-4 text-slate-400"></i>
                </div>
                <a href='/subscriptions/new' class="w-full sm:w-auto px-6 py-3 bg-slate-900 text-white rounded-xl font-bold hover:bg-black transition-all flex items-center justify-center gap-2">
                    <i class="ph-bold ph-plus"></i> Add New
                </a>
            </div>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6" id="subscriptionGrid">
            ${Array.isArray(subscriptions) && subscriptions.length > 0 ? subscriptions.map(subscription => `
                <div class="subscription-card bg-white rounded-2xl border border-slate-100 p-6 flex flex-col gap-4 shadow-sm hover:shadow-md transition-all">
                    <div class="flex items-center gap-4">
                        ${subscription.icon ? 
                            `<img src="${subscription.icon}" alt="${subscription.name}" class="w-12 h-12 rounded-xl object-cover bg-slate-100">` : 
                            `<div class="w-12 h-12 rounded-xl bg-slate-900 flex items-center justify-center text-white font-bold text-lg">
                                ${subscription.providerName.charAt(0).toUpperCase()}
                            </div>`
                        }
                        <div>
                            <h2 class="sub-name text-lg font-bold text-slate-900 leading-tight">${subscription.providerName}</h2>
                            <p class="text-slate-500 text-sm font-medium">${subscription.category || 'Subscription'}</p>
                        </div>
                    </div>
                    <div class="flex items-center justify-between mt-2 pt-4 border-t border-slate-50">
                         <span class="text-xl font-black text-slate-900">#${subscription.amount || '0.00'}</span>
                         <a href="/subscriptions/${subscription._id}" class="text-sm font-bold text-slate-400 hover:text-slate-900 transition-colors">Details</a>
                    </div>
                </div>
            `).join('') : `
                <div class="col-span-full py-20 text-center bg-slate-50 rounded-3xl border-2 border-dashed border-slate-200">
                    <p class="text-slate-400 font-medium font-bold">No subscriptions yet.</p>
                </div>
            `}
        </div>

        <script>
            const searchInput = document.getElementById('subscriptionSearch');
            const subscriptionGrid = document.getElementById('subscriptionGrid');

            searchInput.addEventListener('input', () => {
                const query = searchInput.value.toLowerCase();
                const cards = subscriptionGrid.querySelectorAll('.subscription-card');

                cards.forEach(card => {
                    const name = card.querySelector('.sub-name').textContent.toLowerCase();
                    if (name.includes(query)) {
                        card.style.display = '';
                    } else {
                        card.style.display = 'none';
                    }
                });
            });
        </script>
    `
%>
<%- include('layout') %>