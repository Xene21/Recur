<%
    body = `
        <div class="flex flex-col lg:flex-row lg:items-center justify-between gap-6 mb-12">
            <div>
                <h1 class="text-4xl font-extrabold tracking-tighter text-slate-900">Your Subscriptions</h1>
                <p class="text-slate-500">Manage your active subscriptions and keep track of your spending.</p>
            </div>
            <div class="flex flex-col sm:flex-row items-center gap-4">
                <div class="relative w-full sm:w-64">
                    <input 
                        type="text" 
                        id="subscriptionSearch" 
                        placeholder="Search subscriptions..." 
                        class="w-full pl-10 pr-4 py-3 bg-white border border-slate-200 rounded-xl focus:ring-2 focus:ring-slate-900 outline-none transition-all shadow-sm"
                    >
                    <i class="ph-bold ph-magnifying-glass absolute left-3 top-4 text-slate-400"></i>
                </div>
                <a href='/subscriptions/new' class="w-full sm:w-auto px-6 py-3 bg-slate-900 text-white rounded-xl font-bold hover:bg-black transition-all flex items-center justify-center gap-2">
                    <i class="ph-bold ph-plus"></i> Add New
                </a>
            </div>
        </div>

        <div class="flex flex-col gap-4" id="subscriptionGrid">
            ${Array.isArray(subscriptions) && subscriptions.length > 0 ? subscriptions.map(subscription => {
                const initial = subscription.providerName ? subscription.providerName.charAt(0).toUpperCase() : 'S';
                const price = typeof subscription.amount === 'number' ? subscription.amount.toFixed(2) : subscription.amount;
                const formattedDate = new Date(subscription.renewalDate).toLocaleDateString('en-US', {
                    month: 'short', day: 'numeric', year: 'numeric'
                });
                
                return `
                <div onclick="window.location.href='/subscriptions/${subscription._id}'" class="subscription-card cursor-pointer group bg-white rounded-3xl border border-slate-200 p-4 sm:p-6 flex flex-col sm:flex-row sm:items-center justify-between gap-6 shadow-sm hover:shadow-md hover:border-slate-300 transition-all relative overflow-hidden">
                    
                    <!-- Decorative hover accent -->
                    <div class="absolute left-0 top-0 bottom-0 w-1 bg-slate-900 opacity-0 group-hover:opacity-100 transition-opacity"></div>

                    <div class="flex items-center gap-6">
                        <!-- Icon/Initial -->
                        ${subscription.icon ? 
                            `<img src="${subscription.icon}" alt="${subscription.providerName}" class="w-16 h-16 rounded-2xl object-cover bg-slate-50 border border-slate-100 shadow-sm shrink-0">` 
                            : 
                            `<div class="w-16 h-16 rounded-2xl bg-slate-50 border border-slate-100 flex items-center justify-center text-slate-900 font-extrabold text-2xl shadow-sm shrink-0">
                                ${initial}
                            </div>`
                        }
                        
                        <!-- Info -->
                        <div>
                            <h2 class="sub-name text-xl font-bold text-slate-900 mb-1">${subscription.providerName}</h2>
                            <div class="flex items-center gap-3 text-sm">
                                <span class="px-2 py-0.5 bg-slate-100 text-slate-500 font-bold uppercase tracking-widest text-[10px] rounded-md border border-slate-200">
                                    ${subscription.category || 'Service'}
                                </span>
                                <span class="text-slate-400 font-medium flex items-center gap-1">
                                    <i class="ph-bold ph-arrows-clockwise"></i> ${subscription.billingCycle || 'Monthly'}
                                </span>
                            </div>
                        </div>
                    </div>

                    <div class="flex items-center justify-between sm:justify-end gap-8 border-t sm:border-t-0 border-slate-100 pt-4 sm:pt-0">
                        <!-- Renewal Date Block -->
                        <div class="text-left sm:text-right hidden md:block">
                            <p class="text-xs font-bold text-slate-400 uppercase tracking-widest mb-1">Renews On</p>
                            <p class="text-slate-700 font-medium">${formattedDate}</p>
                        </div>
                        
                        <!-- Price Block -->
                        <div class="text-right">
                             <p class="text-xs font-bold text-slate-400 uppercase tracking-widest mb-1">Cost</p>
                             <div class="flex items-baseline justify-end gap-1">
                                <span class="text-slate-400 font-bold">#</span>
                                <span class="text-2xl font-black text-slate-900">${price}</span>
                             </div>
                        </div>

                        <!-- Action Arrow -->
                        <div class="w-10 h-10 rounded-full bg-slate-50 border border-slate-100 flex items-center justify-center text-slate-400 group-hover:bg-slate-900 group-hover:text-white group-hover:border-slate-900 transition-all ml-2 shrink-0">
                            <i class="ph-bold ph-caret-right"></i>
                        </div>
                    </div>
                </div>
            `}).join('') : `
                <div class="py-20 text-center bg-slate-50 rounded-3xl border-2 border-dashed border-slate-200">
                    <div class="w-20 h-20 bg-white rounded-full flex items-center justify-center border border-slate-100 shadow-sm mx-auto mb-6 text-slate-300">
                        <i class="ph-bold ph-ghost text-4xl"></i>
                    </div>
                    <h3 class="text-xl font-bold text-slate-900 mb-2">No subscriptions found</h3>
                    <p class="text-slate-500 font-medium mb-8">You haven't added any subscriptions to track yet.</p>
                    <a href="/subscriptions/new" class="inline-flex items-center gap-2 px-6 py-3 bg-slate-900 text-white rounded-xl font-bold hover:bg-black transition-all shadow-sm">
                        <i class="ph-bold ph-plus"></i> Add Your First Subscription
                    </a>
                </div>
            `}
        </div>

        <script>
            const searchInput = document.getElementById('subscriptionSearch');
            const subscriptionGrid = document.getElementById('subscriptionGrid');

            searchInput.addEventListener('input', () => {
                const query = searchInput.value.toLowerCase();
                const cards = subscriptionGrid.querySelectorAll('.subscription-card');

                cards.forEach(card => {
                    const name = card.querySelector('.sub-name').textContent.toLowerCase();
                    if (name.includes(query)) {
                        card.style.display = 'flex'; // Changed to flex since we use flex layout for cards
                    } else {
                        card.style.display = 'none';
                    }
                });
            });
        </script>
    `
%>
<%- include('layout') %>