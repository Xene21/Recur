<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= typeof title !== 'undefined' ? title : 'Recur | Subscription Tracker' %></title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/@phosphor-icons/web"></script>
    <script id="MathJax-script" async src="https://cdn.jsdelivr.net/npm/mathjax@3/es5/tex-mml-chtml.js"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Outfit:wght@600;800&display=swap');
        body { font-family: 'Inter', sans-serif; min-height: 100vh; display: flex; flex-direction: column; background: #f1f5f9; }
        .glass-nav { background: rgba(255, 255, 255, 0.7); backdrop-filter: blur(12px); }
        .logo-font { font-family: 'Outfit', sans-serif; }
        .styled-r-small { background: linear-gradient(135deg, #0f172a 0%, #334155 100%); }
    </style>
</head>
<body class="text-slate-900">

    <%- include('header') %>

    <main class="pt-32 pb-12 flex-grow">
        <div class="max-w-7xl mx-auto px-6">
            <%- body %>
        </div>
    </main>

    <%- include('footer') %>

</body>
</html>