<%
  // Function to determine logo placeholder or icon and colors bases on category/providerName
  // We can just use an icon. Let's make an initial letter or generic brand setup.
  const initials = subscription.providerName ? subscription.providerName.substring(0, 2).toUpperCase() : 'SUB';
  
  // Format dates and currency
  const formattedDate = new Date(subscription.renewalDate).toLocaleDateString('en-US', {
      weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' 
  });
  
  const price = typeof subscription.amount === 'number' ? subscription.amount.toFixed(2) : subscription.amount;

  body = `
    <div class="mb-8">
        <a href="/dashboard" class="inline-flex items-center gap-2 text-slate-500 hover:text-slate-900 transition-colors text-sm font-semibold mb-6">
            <i class="ph-bold ph-arrow-left"></i> Back to Dashboard
        </a>
        
        <div class="flex flex-col md:flex-row md:items-end justify-between gap-6">
            <div class="flex items-center gap-6">
                <!-- Large Logo/Initial Circle -->
                <div class="w-24 h-24 rounded-[2rem] styled-r-small flex items-center justify-center text-white text-3xl font-extrabold shadow-lg">
                    ${initials}
                </div>
                <div>
                    <span class="inline-block px-3 py-1 bg-slate-100 text-slate-500 text-xs font-bold uppercase tracking-widest rounded-full mb-3 shadow-sm border border-slate-200">
                        ${subscription.category || 'Subscription'}
                    </span>
                    <h1 class="text-4xl md:text-5xl font-extrabold tracking-tighter text-slate-900">${subscription.providerName}</h1>
                </div>
            </div>
            
            <div class="flex items-center gap-3">
                <button class="px-5 py-3 bg-white border border-slate-200 text-slate-700 rounded-xl font-bold hover:bg-slate-50 hover:border-slate-300 transition-all flex items-center gap-2 shadow-sm">
                    <i class="ph-bold ph-pencil-simple"></i> Edit
                </button>
                <button 
                  id="delete-sub-btn" 
                  data-id="${subscription._id}"
                  class="px-5 py-3 bg-red-50 text-red-600 border border-red-100 rounded-xl font-bold hover:bg-red-500 hover:text-white hover:border-red-500 transition-all flex items-center gap-2 shadow-sm">
                    <i class="ph-bold ph-trash"></i> Delete
                </button>
            </div>
        </div>
    </div>

    <!-- Main Content Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        
        <!-- Left Side: Costs & Billing info -->
        <div class="lg:col-span-2 flex flex-col gap-8">
            <div class="bg-white border border-slate-200 rounded-[2.5rem] p-8 md:p-10 shadow-sm relative overflow-hidden group">
                <!-- Decorative background element for aesthetics -->
                <div class="absolute -right-20 -top-20 w-64 h-64 bg-slate-50 rounded-full blur-3xl opacity-50 group-hover:bg-slate-100 transition-colors duration-500 pointer-events-none"></div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-10 relative z-10">
                    <div>
                        <p class="text-sm font-bold text-slate-400 uppercase tracking-widest mb-3">Cost</p>
                        <div class="flex items-baseline gap-2">
                            <span class="text-3xl font-bold text-slate-400">#</span>
                            <h2 class="text-6xl font-extrabold tracking-tighter text-slate-900">${price}</h2>
                            <span class="text-lg font-medium text-slate-500 ml-1">/ ${subscription.billingCycle || 'month'}</span>
                        </div>
                    </div>
                    
                    <div>
                        <p class="text-sm font-bold text-slate-400 uppercase tracking-widest mb-3">Billing Cycle</p>
                        <div class="flex items-center gap-4">
                            <div class="w-12 h-12 rounded-2xl bg-slate-50 flex items-center justify-center text-slate-600 border border-slate-100 shadow-sm">
                                <i class="ph-bold ph-arrows-clockwise text-xl"></i>
                            </div>
                            <div>
                                <h3 class="text-xl font-bold text-slate-900 capitalize">${subscription.billingCycle ? subscription.billingCycle : 'Monthly'}</h3>
                                <p class="text-slate-500 text-sm">Recurring payment</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Details List -->
            <div class="bg-white border border-slate-200 rounded-[2.5rem] overflow-hidden shadow-sm">
                <div class="p-8 border-b border-slate-100">
                    <h3 class="text-xl font-bold text-slate-900">Subscription Details</h3>
                </div>
                <div class="p-0">
                    <div class="flex items-center justify-between p-8 border-b border-slate-50 hover:bg-slate-50 transition-colors">
                        <div class="flex items-center gap-4">
                            <i class="ph-bold ph-calendar-blank text-slate-400 text-xl"></i>
                            <span class="font-medium text-slate-700">Next Renewal</span>
                        </div>
                        <span class="font-bold text-slate-900">${formattedDate}</span>
                    </div>
                    
                    <div class="flex items-center justify-between p-8 border-b border-slate-50 hover:bg-slate-50 transition-colors">
                        <div class="flex items-center gap-4">
                            <i class="ph-bold ph-tag text-slate-400 text-xl"></i>
                            <span class="font-medium text-slate-700">Category</span>
                        </div>
                        <span class="font-bold text-slate-900 capitalize">${subscription.category || 'Uncategorized'}</span>
                    </div>
                    
                    <div class="flex items-center justify-between p-8 hover:bg-slate-50 transition-colors">
                        <div class="flex items-center gap-4">
                            <i class="ph-bold ph-identification-card text-slate-400 text-xl"></i>
                            <span class="font-medium text-slate-700">Subscription ID</span>
                        </div>
                        <span class="font-mono text-xs font-bold text-slate-400 bg-slate-100 px-3 py-1 rounded-lg">
                            ${subscription._id}
                        </span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Right Side: Action/Summary Card -->
        <div class="lg:col-span-1">
            <div class="bg-slate-900 rounded-[2.5rem] p-8 text-white relative overflow-hidden shadow-xl styled-r-small">
                
                <div class="relative z-10">
                    <div class="w-14 h-14 rounded-2xl bg-white/10 backdrop-blur-md flex items-center justify-center text-white border border-white/20 mb-6">
                        <i class="ph-bold ph-bell-ringing text-2xl"></i>
                    </div>
                    <h3 class="text-xl font-bold mb-2">Renewal Reminder</h3>
                    <p class="text-slate-300 text-sm leading-relaxed mb-8">
                        This subscription will auto-renew on <strong class="text-white">${formattedDate}</strong> at the cost of <strong class="text-white">#${price}</strong>.
                    </p>

                    <!-- A mockup progress or status bar -->
                    <div class="space-y-3">
                        <div class="flex justify-between text-xs font-bold text-slate-400 uppercase tracking-widest">
                            <span>Status</span>
                            <span class="text-emerald-400">Active</span>
                        </div>
                        <div class="w-full h-2 bg-slate-800 rounded-full overflow-hidden">
                            <div class="w-full h-full bg-emerald-500 rounded-full"></div>
                        </div>
                    </div>
                </div>

                <!-- Abstract Decorative Shapes -->
                <div class="absolute -bottom-10 -right-10 w-40 h-40 border-[20px] border-white/5 rounded-full z-0"></div>
                <div class="absolute top-10 -right-5 w-20 h-20 border-[10px] border-white/5 rounded-full z-0"></div>
            </div>
        </div>
    </div>

    <!-- Custom Delete Modal Overlay -->
    <div id="delete-modal-backdrop" class="fixed inset-0 bg-slate-900/40 backdrop-blur-sm z-50 flex items-center justify-center opacity-0 pointer-events-none transition-opacity duration-300">
        <!-- Modal Card -->
        <div id="delete-modal-card" class="bg-white rounded-[2rem] p-8 max-w-sm w-full mx-4 shadow-2xl transform scale-95 transition-transform duration-300">
            <div class="w-16 h-16 rounded-2xl bg-red-50 text-red-500 flex items-center justify-center mb-6 border border-red-100 mx-auto">
                <i class="ph-bold ph-warning text-3xl"></i>
            </div>
            <h3 class="text-2xl font-bold text-slate-900 text-center mb-2">Delete Subscription?</h3>
            <p class="text-slate-500 text-center mb-8">
                Are you sure you want to permanently remove <strong class="text-slate-800">${subscription.providerName}</strong>? This action cannot be undone.
            </p>
            <div class="flex gap-4">
                <button id="cancel-delete-btn" class="flex-1 py-3 px-4 bg-white border border-slate-200 text-slate-700 rounded-xl font-bold hover:bg-slate-50 hover:border-slate-300 transition-all">
                    Cancel
                </button>
                <button id="confirm-delete-btn" class="flex-1 py-3 px-4 bg-red-500 text-white rounded-xl font-bold hover:bg-red-600 shadow-md transition-all flex justify-center items-center gap-2">
                    Delete
                </button>
            </div>
        </div>
    </div>
  `
%>

<!-- Client-side Delete Script -->
<script>
document.addEventListener('DOMContentLoaded', () => {
    const deleteBtn = document.getElementById('delete-sub-btn');
    const modalBackdrop = document.getElementById('delete-modal-backdrop');
    const modalCard = document.getElementById('delete-modal-card');
    const cancelBtn = document.getElementById('cancel-delete-btn');
    const confirmBtn = document.getElementById('confirm-delete-btn');
    
    // Determine the ID from the dataset of the triggering button
    let subIdToDelete = null;

    const openModal = () => {
        modalBackdrop.classList.remove('opacity-0', 'pointer-events-none');
        modalCard.classList.remove('scale-95');
    };

    const closeModal = () => {
        modalBackdrop.classList.add('opacity-0', 'pointer-events-none');
        modalCard.classList.add('scale-95');
    };

    if (deleteBtn) {
        deleteBtn.addEventListener('click', () => {
            subIdToDelete = deleteBtn.getAttribute('data-id');
            openModal();
        });
    }

    if (cancelBtn) {
        cancelBtn.addEventListener('click', closeModal);
    }

    if (confirmBtn) {
        confirmBtn.addEventListener('click', async () => {
            if (!subIdToDelete) return;

            // Provide visual feedback inside the modal
            const originalText = confirmBtn.innerHTML;
            confirmBtn.innerHTML = '<i class="ph-bold ph-spinner animate-spin"></i> Deleting...';
            confirmBtn.disabled = true;
            cancelBtn.disabled = true;

            try {
                const response = await fetch('/subscriptions/' + subIdToDelete, {
                    method: 'DELETE',
                });

                if (response.ok) {
                    // Navigate back to the dashboard after successful deletion
                    window.location.href = '/dashboard';
                } else {
                    const data = await response.json();
                    alert('Error deleting subscription: ' + (data.message || 'Unknown error'));
                    // Reset UI if it failed
                    confirmBtn.innerHTML = originalText;
                    confirmBtn.disabled = false;
                    cancelBtn.disabled = false;
                    closeModal();
                }
            } catch (error) {
                console.error('Failed to delete subscription:', error);
                alert('Connection error. Please try again later.');
                confirmBtn.innerHTML = originalText;
                confirmBtn.disabled = false;
                cancelBtn.disabled = false;
                closeModal();
            }
        });
    }

    // Optional: Close modal if clicking on the backdrop
    modalBackdrop.addEventListener('click', (e) => {
        if (e.target === modalBackdrop) {
            closeModal();
        }
    });
});
</script>

<%- include('layout') %>
